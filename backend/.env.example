DB_HOST=localhost
# Use 3307 if MySQL Workbench connects on that port; default install is often 3306
DB_PORT=3307
DB_USER=root
DB_PASSWORD=your_mysql_password
DB_NAME=raghavendra_enge_db
PORT=3000
JWT_SECRET=change-this-to-a-long-random-secret
NODE_ENV=development
# Set to true for cloud MySQL providers (Railway, PlanetScale, Aiven, etc.)
# DB_SSL=true
# Comma-separated origins for CORS (optional in production when frontend is served by this API)
# CORS_ORIGIN=https://your-domain.com